{
  "name": "pipecraft-blog",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun run --watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "serve": "bun run server/index.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "validate": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "bun-types": "latest",
    "concurrently": "^9.1.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@elysiajs/cors": "^1.1.1",
    "elysia": "^1.1.28",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.4",
    "marked-highlight": "^2.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  }
}
